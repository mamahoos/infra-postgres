# postgres_exporter settings (optional — not part of core compose)
# Enable via compose.monitoring.yaml when Prometheus is available.
#
# Build DATA_SOURCE_NAME from your .env — do not commit real credentials:
#   DATA_SOURCE_NAME=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?sslmode=disable
#
# PG_EXPORTER_EXTEND_QUERY_PATH=/etc/postgres-exporter/queries.yaml
