POSTGRES_VERSION=17
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=postgres
POSTGRES_PORT=5432
TZ=UTC

# Backup retention — GFS (Grandfather-Father-Son)
# For personal projects, set BACKUP_RETENTION_DAYS=14 and ignore weekly/monthly promotion.
BACKUP_RETENTION_DAYS=7
BACKUP_RETENTION_WEEKS=4
BACKUP_RETENTION_MONTHS=12
